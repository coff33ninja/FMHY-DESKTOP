{
  "name": "fmhy-browser",
  "version": "0.1.5-alpha",
  "description": "A dedicated ad-free browser for fmhy.net",
  "main": "main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --win portable",
    "dist": "electron-builder --win",
    "lint": "eslint . --ext .js,.json"
  },
  "build": {
    "appId": "net.fmhy.browser",
    "productName": "FMHY Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "webview-preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "overrides": {
    "tar": "7.5.16"
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.6.0",
    "png-to-ico": "^3.0.2"
  }
}
